@model List<PlaylistDto>
@{
    ViewData["Title"] = "Playlists";
}
<div class="page-hero d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <div class="section-chip mb-2">Colecciones personales</div>
        <h2 class="mb-1">Mis playlists</h2>
        <p class="text-muted mb-0">Agrupa tus canciones demo favoritas y reprodúcelas cuando quieras.</p>
    </div>
    <a asp-action="Create" class="btn btn-dark">Nueva playlist</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-secondary">Todavía no tienes playlists. Crea la primera para comenzar.</div>
}

@foreach (var playlist in Model)
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h4 class="mb-1">@playlist.Nombre</h4>
                    <p class="text-muted mb-0">@playlist.Descripcion</p>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@playlist.IdPlaylist" class="btn btn-outline-light btn-sm">Editar</a>
                    <form method="post" asp-action="Delete">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@playlist.IdPlaylist" />
                        <button class="btn btn-outline-danger btn-sm">Eliminar</button>
                    </form>
                </div>
            </div>

            @if (playlist.Canciones.Any())
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Canción</th>
                                <th>Artista</th>
                                <th>Álbum</th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var song in playlist.Canciones)
                        {
                            <tr>
                                <td>@song.Nombre</td>
                                <td>@song.Artista</td>
                                <td>@song.Album</td>
                                <td>
                                    <button type="button" class="btn btn-dark btn-sm play-song"
                                            data-id="@song.IdCancion"
                                            data-title="@song.Nombre"
                                            data-artist="@song.Artista"
                                            data-audio="@song.AudioUrl"
                                            data-cover="@song.ImagenUrl">
                                        Reproducir
                                    </button>
                                </td>
                                <td>
                                    <form method="post" asp-action="RemoveSong">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="playlistId" value="@playlist.IdPlaylist" />
                                        <input type="hidden" name="songId" value="@song.IdCancion" />
                                        <button class="btn btn-outline-danger btn-sm">Quitar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Esta playlist todavía no tiene canciones.</p>
            }
        </div>
    </div>
}
